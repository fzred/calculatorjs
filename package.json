{
    "name": "calculatorjs",
    "version": "1.2.0",
    "description": "Accurate arithmetic library — fixes JavaScript floating point precision, with a built-in expression parser. Zero dependencies.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "unpkg": "./dist/calc.umd.min.js",
    "jsdelivr": "./dist/calc.umd.min.js",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "files": ["dist", "README-ZH.md"],
    "sideEffects": false,
    "scripts": {
        "build": "tsup && node scripts/patch-cjs.mjs",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:dist": "npm run build && node scripts/smoke-dist.mjs",
        "coverage": "vitest run --coverage",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build && node scripts/smoke-dist.mjs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fzred/calculatorjs.git"
    },
    "keywords": [
        "calc",
        "calculator",
        "calculatorjs",
        "precision",
        "arithmetic",
        "decimal",
        "float",
        "floating-point",
        "expression"
    ],
    "author": "lred <1179750402@qq.com> (http://www.lred.me)",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/fzred/calculatorjs/issues"
    },
    "homepage": "https://github.com/fzred/calculatorjs#readme",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "@vitest/coverage-v8": "^2.1.8",
        "tsup": "^8.3.5",
        "typescript": "^5.6.3",
        "vitest": "^2.1.8"
    }
}
